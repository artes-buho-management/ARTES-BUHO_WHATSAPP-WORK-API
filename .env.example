# Server
PORT=3000

# WhatsApp webhook verification token (you choose this value)
WHATSAPP_VERIFY_TOKEN=replace_with_a_strong_secret

# Meta WhatsApp Cloud API credentials
WHATSAPP_ACCESS_TOKEN=replace_with_access_token
WHATSAPP_PHONE_NUMBER_ID=replace_with_phone_number_id
WHATSAPP_BUSINESS_ACCOUNT_ID=replace_with_waba_id
WHATSAPP_API_VERSION=v22.0

# Optional but recommended: validate Meta signature in webhook
META_APP_SECRET=replace_with_meta_app_secret
ALLOW_UNSIGNED_WEBHOOK=true

# Runtime hardening
REQUEST_TIMEOUT_MS=15000
HTTP_RETRY_ATTEMPTS=2
HTTP_RETRY_BASE_MS=300
DEDUPE_TTL_MS=600000
LOG_WEBHOOK_PAYLOAD=false
MAX_INBOUND_CHARS=4000

# Gemini integration
GEMINI_API_KEY=replace_with_gemini_api_key
GEMINI_MODEL=gemini-2.5-pro
GEMINI_ENABLED=true
GEMINI_MAX_OUTPUT_TOKENS=2048
GEMINI_SYSTEM_PROMPT=Eres un asistente profesional para soporte de clientes por WhatsApp. Responde claro, breve y con tono amable.
